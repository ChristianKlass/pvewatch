# PVEWatch configuration — copy to .env and fill in your values.
# See README.md for setup instructions.
# WARNING: do not add inline comments after values (e.g. VAR=value # comment)
#          Docker env-file parsing treats everything after = as the value.

# --- Proxmox connection (required) ---
PVE_HOST=192.168.1.100
PVE_PORT=8006
PVE_NODE=pve
PVE_TOKEN_ID=monitoring@pve!pvewatch
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PVE_VERIFY_SSL=false

# --- Email alerts (at least one of email or Discord is required) ---
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=you@gmail.com
ALERT_EMAIL_SMTP_PASS=your-app-password
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=pvewatch@example.com

# --- Discord alerts ---
# ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN

# --- Polling and schedule ---
POLL_INTERVAL_MINUTES=15
DIGEST_DAY=sunday
DIGEST_HOUR=9

# --- Storage alert threshold (percent) ---
STORAGE_ALERT_THRESHOLD=85

# --- Web UI ---
WEB_UI_ENABLED=true
WEB_UI_PORT=8080

# --- Data retention ---
DATA_PATH=/data
HISTORY_DAYS=30

# --- Database ---
# Three options:
#   Unset (default): SQLite at DATA_PATH/pvewatch.db — simplest, no setup needed
#   PostgreSQL:      full persistence, recommended for k8s
#   memory:          in-memory SQLite — no persistence, history re-pulled from Proxmox on
#                    every restart; alerts may re-fire on restart, no weekly digest
#
# DATABASE_URL=postgresql://user:password@host:5432/pvewatch
# DATABASE_URL=memory
