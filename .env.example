# PVEWatch configuration
# Copy this to .env and fill in your values.
# See README.md for step-by-step setup instructions.

# --- Proxmox connection (required) ---
PVE_HOST=192.168.1.100         # IP or hostname of your Proxmox node
PVE_PORT=8006                  # default 8006
PVE_NODE=pve                   # node name shown in the Proxmox web UI sidebar
PVE_TOKEN_ID=monitoring@pve!pvewatch
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PVE_VERIFY_SSL=false           # set true only if you have a valid certificate

# --- Email alerts (optional, but at least one alert target is required) ---
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=you@gmail.com
ALERT_EMAIL_SMTP_PASS=your-app-password
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=pvewatch@example.com

# --- Discord alerts (optional) ---
ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN

# --- Polling and schedule ---
POLL_INTERVAL_MINUTES=15       # how often to check for new backup tasks
DIGEST_DAY=sunday              # day to send weekly digest (monday-sunday)
DIGEST_HOUR=9                  # hour to send weekly digest (0-23, container local time)

# --- Storage alert threshold ---
STORAGE_ALERT_THRESHOLD=85     # alert when any storage pool exceeds this % usage

# --- Web UI ---
WEB_UI_ENABLED=true
WEB_UI_PORT=8080

# --- Data retention ---
DATA_PATH=/data                # path inside the container (mount a volume here)
HISTORY_DAYS=30                # days of backup history to retain
